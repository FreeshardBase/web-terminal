    "http-proxy-middleware": "^1.0.6",
    "lodash": "^4.17.21",
    "marked": "^4.1.1",
    "mobile-device-detect": "^0.4.3",
    "moment": "^2.29.4",
    "qrcode.vue": "^1.7.0",
    "vue": "^2.6.11",
    "vue-router": "^3.2.0",
    "vue-tour": "^2.0.0",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-plugin-router": "^4.5.10",
    "@vue/cli-plugin-unit-jest": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^26.6.3",
    "eslint": "^6.7.2",
